# Environment Variables
# Copy this file to .env and fill in the values. Never commit .env to source control.

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=3000
APP_SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=

# ── Third-party APIs ─────────────────────────────────────────────────────────
API_KEY=
API_BASE_URL=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
